<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.Chat_Activity">

    <RelativeLayout
        android:id="@+id/relative_webview_chat"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <WebView
            android:id="@+id/webview"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/relative_alert"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/white">

        <android.support.v7.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:layout_margin="30dp"
            android:background="@drawable/round_edges"
            android:elevation="25dp"
            android:orientation="vertical"
            android:padding="10dp"
            android:visibility="gone"
            app:cardCornerRadius="10dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="350dp"
                android:layout_centerHorizontal="true"
                android:layout_centerVertical="true"
                android:background="@android:color/transparent">

                <TextView
                    android:id="@+id/text_alertoption_chat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="10dp"
                    android:gravity="center|left"
                    android:text="Choose your question."
                    android:textColor="@android:color/black"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <View
                    android:id="@+id/view_alertoptions"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_below="@+id/text_alertoption_chat"
                    android:background="#4F817F81" />

                <ScrollView
                    android:id="@+id/scrollview_alertoption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/view_alertoptions"
                    android:layout_margin="10dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <RadioGroup
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <RadioButton
                                android:id="@+id/radiobtn_alertQ1"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_margin="2dp"
                                android:onClick="onRadioButtonClicked"
                                android:text="Question 1" />

                            <RadioButton
                                android:id="@+id/radiobtn_alertQ2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_margin="2dp"
                                android:onClick="onRadioButtonClicked"
                                android:text="Question 2" />

                            <RadioButton
                                android:id="@+id/radiobtn_alertQ3"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_margin="2dp"
                                android:onClick="onRadioButtonClicked"
                                android:text="Question 3" />

                            <RadioButton
                                android:id="@+id/radiobtn_alertQ4"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_margin="2dp"
                                android:onClick="onRadioButtonClicked"
                                android:text="Question 4" />

                            <RadioButton
                                android:id="@+id/radiobtn_alertQ5"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_margin="2dp"
                                android:onClick="onRadioButtonClicked"
                                android:text="Question 5" />

                            <RadioButton
                                android:id="@+id/radiobtn_alertQother"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_margin="2dp"
                                android:onClick="onRadioButtonClicked"
                                android:text="Other" />

                        </RadioGroup>
                    </RelativeLayout>
                </ScrollView>

                <View
                    android:id="@+id/view_alertunderscroll"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_below="@+id/scrollview_alertoption"
                    android:background="#4F817F81" />

                <Button
                    android:id="@+id/btn_alertOption_ok"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/view_alertunderscroll"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentBottom="true"
                    android:background="@android:color/transparent"
                    android:enabled="false"
                    android:text="OK"
                    android:textColor="@color/colorPrimaryDark"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_alertOption_cancel"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/view_alertunderscroll"
                    android:layout_alignParentBottom="true"
                    android:layout_toLeftOf="@id/btn_alertOption_ok"
                    android:background="@android:color/transparent"
                    android:text="CANCEL"
                    android:textColor="@color/colorPrimaryDark"
                    android:textStyle="bold" />

            </RelativeLayout>
        </android.support.v7.widget.CardView>

        <android.support.v7.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:layout_margin="30dp"
            android:background="@drawable/round_edges"
            android:elevation="25dp"
            android:orientation="vertical"
            android:padding="10dp"
            android:visibility="visible"
            app:cardCornerRadius="10dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_centerHorizontal="true"
                android:layout_centerVertical="true"
                android:background="@android:color/transparent">

                <TextView
                    android:id="@+id/text_alertTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="10dp"
                    android:gravity="center|left"
                    android:text="Enter Email to Start Chat"
                    android:textColor="@android:color/black"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edit_aler_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/text_alertTitle"
                    android:layout_margin="10dp"
                    android:backgroundTint="@color/colorPrimaryDark"
                    android:gravity="center|left"
                    android:hint="add Email"
                    android:imeOptions="actionDone"
                    android:inputType="textEmailAddress"
                    android:lines="1"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:textColor="#524F4F"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_alert_ok"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentBottom="true"
                    android:background="@android:color/transparent"
                    android:text="OK"
                    android:textColor="@color/colorPrimaryDark"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_alert_cancel"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_toLeftOf="@id/btn_alert_ok"
                    android:background="@android:color/transparent"
                    android:text="CANCEL"
                    android:textColor="@color/colorPrimaryDark"
                    android:textStyle="bold" />
            </RelativeLayout>
        </android.support.v7.widget.CardView>
    </RelativeLayout>
</RelativeLayout>